{
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": ["supabase"]
  },
  "scripts": {
    "mobile": "pnpm --filter mobile start",
    "admin": "pnpm --filter admin dev",
    "dev": "concurrently \"pnpm mobile\" \"pnpm admin\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "supabase:push": "supabase db push",
    "supabase:gen-types": "supabase gen types typescript --local > packages/supabase-client/src/types.ts"
  },
  "devDependencies": {
    "concurrently": "^9",
    "supabase": "^2.87.2"
  }
}
