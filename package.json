{
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  },
  "scripts": {
    "admin": "pnpm --filter admin dev",
    "dev": "pnpm admin",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "supabase:push": "supabase db push",
    "supabase:gen-types": "supabase gen types typescript --local > packages/supabase-client/src/types.ts"
  },
  "devDependencies": {
    "supabase": "^2.87.2"
  },
  "dependencies": {
    "caniuse-lite": "^1.0.30001787"
  }
}
