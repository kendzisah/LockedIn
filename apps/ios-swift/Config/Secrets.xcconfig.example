// Example secrets file. Copy to Secrets.xcconfig (gitignored) and fill in
// real values. Pulled in via `#include? "Secrets.xcconfig"` in Shared.xcconfig.
//
// IMPORTANT: xcconfig values cannot contain `//`. The xcconfig parser will
// interpret any `//` as the start of a line comment, so URLs must be escaped
// by splitting the slashes with `$()`. For example:
//   SUPABASE_URL = https:/$()/your-project.supabase.co

// Supabase
SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-anon-key
SUPABASE_PASSWORD_RESET_REDIRECT = https:/$()/locked-in.co/auth/callback?next=/auth/reset-password

// RevenueCat
REVENUECAT_IOS_API_KEY = appl_your_revenuecat_key

// AppsFlyer
APPSFLYER_DEV_KEY = your_appsflyer_dev_key
APPSFLYER_APP_ID = 0000000000

// Urls / links
IOS_APP_STORE_URL = https:/$()/apps.apple.com/app/idXXXXXXXXX
PRIVACY_URL = https:/$()/locked-in.co/privacy
TERMS_URL = https:/$()/locked-in.co/terms

// PostHog
POSTHOG_API_KEY = your_posthog_project_api_key
POSTHOG_HOST = https:/$()/us.i.posthog.com
