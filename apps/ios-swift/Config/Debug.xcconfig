// Debug configuration. Inherits from Shared then declares secret placeholders.
// Provide real values via local Config/Secrets.xcconfig or a CI build step that
// writes Secrets.xcconfig before building. Do NOT commit values to git.

#include "Shared.xcconfig"

SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG
SWIFT_OPTIMIZATION_LEVEL = -Onone
GCC_OPTIMIZATION_LEVEL = 0
ONLY_ACTIVE_ARCH = YES

// ─── LLDB attach-speed tuning (debug builds only) ───
// `dwarf` (not `dwarf-with-dsym`) skips dSYM-bundle generation on every build —
// huge savings with many SPM deps. Release stays on dwarf-with-dsym for crash
// symbolication.
DEBUG_INFORMATION_FORMAT = dwarf
// Don't ask the indexer to also write a clang index store during compile —
// LLDB doesn't need it and it doubles parser work.
COMPILER_INDEX_STORE_ENABLE = NO
// Skip building Swift modules' textual interfaces in debug.
BUILD_LIBRARY_FOR_DISTRIBUTION = NO
// Don't strip symbols from third-party dylibs at copy-resources time — LLDB
// otherwise has to re-resolve them per attach.
COPY_PHASE_STRIP = NO

// ─── Secrets (placeholders) ───
SUPABASE_URL = $(inherited)
SUPABASE_ANON_KEY = $(inherited)
SUPABASE_PASSWORD_RESET_REDIRECT = $(inherited)
REVENUECAT_IOS_API_KEY = $(inherited)
APPSFLYER_DEV_KEY = $(inherited)
APPSFLYER_APP_ID = $(inherited)
IOS_APP_STORE_URL = $(inherited)
PRIVACY_URL = $(inherited)
TERMS_URL = $(inherited)
POSTHOG_API_KEY = $(inherited)
POSTHOG_HOST = $(inherited)
